# Base URL for generating shareable links (auto-detected on Vercel)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Database Provider: "memory" (default) | "supabase"
# "memory" = no external DB needed, cards stored in URL (recommended)
# "supabase" = only used when card payload exceeds URL length limit
DATABASE_PROVIDER=memory

# Supabase (optional — only needed if DATABASE_PROVIDER=supabase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
